{
  "manifest_version": 3,
  "name": "YT Music Lyrics Popup",
  "version": "1.0.0",
  "description": "YouTube Music pop-up lyrics real time with synced lyrics",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://music.youtube.com/*",
    "https://www.youtube.com/*",
    "https://lrclib.net/*",
    "https://unison.boidu.dev/*",
    "https://api.lrcmux.dev/*",
    "https://translate.googleapis.com/*",
    "https://lyrics.api.dacubeking.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["sources.js", "sources-ui.js", "content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["style.css", "injected.js"],
      "matches": ["https://music.youtube.com/*"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
